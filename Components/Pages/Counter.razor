@page "/"
@rendermode InteractiveServer
@inject ICounterService CounterService

<PageTitle>Counter</PageTitle>

<div class="d-flex align-items-center justify-content-center px-3 py-4 singleton-page min-vh-100">
    <div class="p-4 p-md-5 text-center singleton-card">
        <h1 class="mb-2 text-warning display-4 fw-bold">Global Singleton Counter</h1>
        <p class="mb-3 lead singleton-subtitle">Shared across all users and tabs</p>
        <hr class="my-3" />

        <h2 class="my-4 singleton-count singleton-count-color fw-bold" role="status">@CounterService.Count</h2>

        <button class="w-100 text-uppercase btn btn-warning singleton-button fw-bold"
                @onclick="CounterService.Increment">
            Increment Global State
        </button>

        <button class="mt-4 w-100 text-uppercase btn btn-danger singleton-button fw-bold"
                @onclick="CounterService.Reset">
            Reset Global State
        </button>

        <p class="mt-4 mb-0 fst-italic singleton-hint">Open this in another tab to see the magic!</p>
    </div>
</div>

@code {
    protected override void OnInitialized()
    {
        // Subscribe to the event
        CounterService.OnChange += HandleStateChanged;
    }

    private async void HandleStateChanged()
    {
        // We call InvokeAsync because the event might come from a different
        // thread/circuit, and we need to tell Blazor to re-render the UI.
        await InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        // UN-subscribe when the component is destroyed
        CounterService.OnChange -= HandleStateChanged;
    }
}